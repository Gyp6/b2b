{
  "name": "b2b",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky install"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "eslint . --fix --no-cache --max-warnings=0 --no-warn-ignored",
			"prettier --write --ignore-unknown"
    ],
    "packages/**/*.{ts,tsx}": [
      "eslint . --fix --no-cache --max-warnings=0 --no-warn-ignored",
			"prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "lint-staged": "^16.3.2",
    "prettier": "3.8.1",
    "turbo": "2.8.14",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
